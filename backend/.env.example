# ==============================================================
# VoyagerAI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file — only this .example stays in git.
# ==============================================================

# ---------- App ----------
ENVIRONMENT=development                # development | production
DEBUG=true
API_V1_PREFIX=/v1
CORS_ORIGINS=http://localhost:3000     # comma-separated; add Vercel URL in prod

# ---------- Auth / JWT ----------
# Generate with: openssl rand -hex 32   (or click "Generate" in Render dashboard)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ---------- Database (Neon Postgres + pgvector) ----------
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=

# For local Docker Compose dev only (overrides DATABASE_URL when running locally)
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voyagerai

# ---------- Redis (Render Key Value) ----------
# Use the Internal Connection String from Render, not the external one
REDIS_URL=
LOCAL_REDIS_URL=redis://localhost:6379/0

# ---------- AI Models (Gemini) ----------
GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ---------- External APIs ----------
OPENWEATHER_API_KEY=
TAVILY_API_KEY=
OPENROUTESERVICE_API_KEY=
LOCATIONIQ_API_KEY=

# ---------- Email (for password reset — Resend free tier, no card) ----------
# Sign up: https://resend.com  |  Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@voyagerai.app
FRONTEND_RESET_URL=http://localhost:3000/reset-password   # token gets appended as ?token=

# ---------- Observability ----------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=voyagerai
LANGSMITH_TRACING=true
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ---------- Sharing ----------
SHARE_LINK_EXPIRE_DAYS=30

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60
FLIGHT_CACHE_TTL_SECONDS=21600          # 6h, matches Week 5 cache pattern
SESSION_TTL_SECONDS=86400               # 24h short-term memory (Week 9)

# ---------- PDF Export ----------
PDF_ENGINE=weasyprint                   # weasyprint | puppeteer

# ---------- Frontend (goes in frontend/.env.local, not backend) ----------
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
